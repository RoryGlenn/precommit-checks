{
  "name": "precommit-checks",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Non-blocking Git pre-commit checks for ESLint and Prettier.",
  "scripts": {
    "prepare": "husky install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "build": "vite build",
    "test:precommit": "node scripts/precommit.mjs",
    "test:prepush": "node scripts/prepush.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,mjs}": [
      "eslint",
      "node scripts/check-format.mjs"
    ],
    "*.{json,css,scss,md,html,yml,yaml}": [
      "node scripts/check-format.mjs"
    ]
  },
  "devDependencies": {
    "boxen": "^8.0.1",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.0.0",
    "vite": "^8.1.0"
  },
  "dependencies": {}
}
