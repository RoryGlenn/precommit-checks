{
  "name": "commitment-issues",
  "version": "1.0.0",
  "type": "module",
  "description": "Commitment Issues: advisory pre-commit checks that nudge, never block.",
  "license": "MIT",
  "author": "Rory Glenn",
  "homepage": "https://github.com/RoryGlenn/Commitment-Issues#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RoryGlenn/Commitment-Issues.git"
  },
  "bugs": {
    "url": "https://github.com/RoryGlenn/Commitment-Issues/issues"
  },
  "keywords": [
    "pre-commit",
    "husky",
    "lint-staged",
    "eslint",
    "prettier",
    "git-hooks",
    "advisory",
    "non-blocking"
  ],
  "files": [
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "husky",
    "init": "node scripts/init.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "commit:fix": "node scripts/commit-fix.mjs",
    "fix:staged": "node scripts/fix-staged.mjs",
    "test": "node --test test/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.mjs",
    "test:precommit": "node scripts/precommit-unified.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,mts,cts}": [
      "node scripts/fix-staged-js.mjs"
    ],
    "*.{json,css,scss,md,html,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "precommitChecks": {
    "testExempt": [
      "scripts/lib/**"
    ],
    "blockPushOnTestFailure": true
  },
  "devDependencies": {
    "boxen": "^8.0.1",
    "eslint": "^9.39.4",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
